{
  "version": "0.1",
  "defaults": {
    "cwd": ".",
    "stdout": "logs/${asset}.out",
    "stderr": "logs/${asset}.err",
    "start_grace_sec": 1,
    "delay_sec": 1,
    "env": {
      "set": {
        "HAKO_PROFILE_SERVICE_CLIENT": "${HAKO_PROFILE_SERVICE_CLIENT:-0}"
      },
      "prepend": {
        "lib_path": [
          "/usr/local/hakoniwa/lib"
        ],
        "PATH": [
          "/usr/local/hakoniwa/bin"
        ]
      }
    }
  },
  "assets": [
    {
      "name": "drone-service-1",
      "activation_timing": "before_start",
      "command": "/root/workspace/lnx/linux-main_hako_drone_service",
      "args": [
        "config/drone/fleets/api-current.json",
        "config/pdudef/drone-pdudef-current.json"
      ],
      "cwd": "${HAKO_DRONE_PROJECT_PATH}",
      "delay_sec": 2
    },
    {
      "name": "show-asset-runner",
      "activation_timing": "before_start",
      "command": "bash",
      "args": [
        "drone_api/external_rpc/apps/run_show_asset.bash",
        "--service-config",
        "config/drone/fleets/services/api-current-service.json",
        "--show-json",
        "config/drone-show-config/show-hakoniwa-100-ref.json",
        "--drone-count",
        "100",
        "--asset-name",
        "ShowRunnerAsset",
        "--proc-count",
        "1",
        "--assign-mode",
        "nearest",
        "--speed",
        "14.0",
        "--timeout-sec",
        "120.0",
        "--delta-time-msec",
        "20",
        "--final-hold-extra-sec",
        "5.0",
        "--z-offset-m",
        "0.0",
        "--summary-json",
        "/root/workspace/logs/perf/show_asset_summary_n100_p1.json"
      ],
      "cwd": "${HAKO_DRONE_PROJECT_PATH}",
      "env": {
        "prepend": {
          "PYTHONPATH": [
            "${HAKO_DRONE_PROJECT_PATH}/work/hakoniwa-pdu-python/src"
          ]
        }
      },
      "depends_on": [
        "drone-service-1"
      ],
      "delay_sec": 1
    },
    {
      "name": "visual-state-publisher",
      "activation_timing": "before_start",
      "command": "/root/workspace/lnx/linux-drone_visual_state_publisher",
      "args": [
        "/root/workspace/config/assets/visual_state_publisher/visual_state_publisher.runtime.json"
      ],
      "cwd": "${HAKO_DRONE_PROJECT_PATH}",
      "depends_on": [
        "show-asset-runner"
      ],
      "delay_sec": 2
    },
    {
      "name": "web-bridge-fleets",
      "activation_timing": "before_start",
      "command": "/usr/local/hakoniwa/bin/hakoniwa-pdu-web-bridge",
      "args": [
        "--config-root",
        "/usr/local/hakoniwa/share/hakoniwa-pdu-bridge/config/web_bridge_fleets",
        "--node-name",
        "web_bridge_fleets_node1",
        "--delta-time-step-usec",
        "20000",
        "--enable-ondemand"
      ],
      "cwd": "${HAKO_DRONE_PROJECT_PATH}",
      "depends_on": [
        "visual-state-publisher"
      ]
    },
    {
      "name": "threejs-viewer-webserver",
      "activation_timing": "after_start",
      "command": "python3",
      "args": [
        "-m",
        "http.server",
        "8000"
      ],
      "cwd": "${HAKO_THREEJS_VIEWER_PATH}",
      "depends_on": [
        "web-bridge-fleets"
      ]
    },
    {
      "name": "perf-monitor",
      "activation_timing": "after_start",
      "command": "bash",
      "args": [
        "tools/start-perf-monitor.bash",
        "${FLEET_DRONE_COUNT:-1}",
        "${PERF_LABEL:-fleets_scale_n1}",
        "${PERF_DURATION_SEC:-86400}"
      ],
      "cwd": "${HAKO_DRONE_PROJECT_PATH}",
      "depends_on": [
        "web-bridge-fleets"
      ]
    },
    {
      "name": "host-perf-monitor",
      "activation_timing": "after_start",
      "command": "bash",
      "args": [
        "tools/start-host-perf-monitor.bash",
        "${FLEET_DRONE_COUNT:-1}",
        "${PERF_LABEL:-fleets_scale_n1}",
        "${PERF_DURATION_SEC:-86400}"
      ],
      "cwd": "${HAKO_DRONE_PROJECT_PATH}",
      "depends_on": [
        "web-bridge-fleets"
      ]
    }
  ]
}
